# AI Hospital OS — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# ── Database (PostgreSQL) ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hospital_os
DB_USER=hospital
DB_PASSWORD=change_in_production

# ── MLflow experiment tracking ────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///mlruns.db
MLFLOW_ARTIFACT_ROOT=/data/mlflow/artifacts

# ── FHIR R4 server (optional) ────────────────────────────
FHIR_SERVER_URL=http://localhost:8080/fhir

# ── API server ────────────────────────────────────────────
API_PORT=8000
API_WORKERS=4

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_PORT=8050

# ── WebSocket server ──────────────────────────────────────
WS_PORT=8765

# ── Data directories ─────────────────────────────────────
DATA_RAW_DIR=/data/raw
DATA_CLEAN_DIR=/data/clean
DATA_FEATURES_DIR=/data/features
MODEL_DIR=/data/models
DATA_REPORTS_DIR=/data/reports

# ── Airflow (optional) ───────────────────────────────────
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLt0nfdstY=
AIRFLOW_SECRET_KEY=hospital_os_secret

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
HOSPITAL_OS_ENV=development

# ── Override any config via HOSPITAL_OS__SECTION__KEY ─────
# Examples:
# HOSPITAL_OS__ALERTS__NEWS2_CRITICAL_THRESHOLD=9
# HOSPITAL_OS__ML__SEPSIS_ALERT_THRESHOLD=0.55
# HOSPITAL_OS__SECURITY__SESSION_TIMEOUT_MINUTES=480
